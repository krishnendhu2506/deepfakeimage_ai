{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "fake_image_detector/**",
      "requirements.txt",
      "Procfile",
      "wsgi.py",
      "main.py",
      "nixpacks.toml",
      "pyproject.toml",
      ".python-version"
    ]
  },
  "deploy": {
    "startCommand": "gunicorn wsgi:app",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
